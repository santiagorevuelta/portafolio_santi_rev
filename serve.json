{
  "rewrites": [
    {
      "source": "!/static/**",
      "destination": "/index.html"
    },
    {
      "source": "!/privacy-policy.html",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "!/terms-of-service.html",
      "destination": "/terms-of-service.html"
    },
    {
      "source": "!/user-agreement.html",
      "destination": "/user-agreement.html"
    },
    {
      "source": "!/legal-documents.html",
      "destination": "/legal-documents.html"
    },
    {
      "source": "!/legal-docs-config.json",
      "destination": "/legal-docs-config.json"
    },
    {
      "source": "!/assets/**",
      "destination": "/index.html"
    }
  ]
}
